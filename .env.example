# Copy this file to .env. No API keys are required for the included feeds.
PORT=3000
CACHE_SECONDS=90

# Texas districts. ALL polls every TxDOT district; use SAT while debugging.
TXDOT_DISTRICTS=ALL
TXDOT_DEBUG=0

# Set a source debug flag to 1 to save its page/data response under debug/.
PA511_DEBUG=0
GA511_DEBUG=0
NY511_DEBUG=0
LA511_DEBUG=0
WI511_DEBUG=0
AZ511_DEBUG=0
NE511_DEBUG=0
AK511_DEBUG=0
NV511_DEBUG=0
FL511_DEBUG=0
ID511_DEBUG=0
NC511_DEBUG=0
CA511_DEBUG=0

# Shared 511-family pagination. Most sites cap each response at 100 records.
DMS_511_PAGE_SIZE=100
DMS_511_MAX_PAGES=100

# Save raw responses when Oklahoma or Alabama needs field tuning.
OKTRAFFIC_DEBUG=0
ALGO_DEBUG=0

# Background source refresh interval (minimum 60 seconds)
AUTO_REFRESH_SECONDS=120
